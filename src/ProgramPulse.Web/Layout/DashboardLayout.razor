@inherits LayoutComponentBase
@inject AuthApiClient AuthApi
@inject NavigationManager Navigation

<div class="pp-app">
    <!-- ===== SIDEBAR ===== -->
    <aside class="pp-sidebar">
        <a href="/" class="pp-logo pp-sidebar__logo">
            <svg class="pp-logo__mark" viewBox="0 0 40 24" fill="none" aria-hidden="true">
                <path d="M1 12 H10 L13 4 L18 20 L23 8 L26 12 H39"
                      stroke="currentColor" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="pp-logo__text">Program<span class="pp-logo__accent">Pulse</span></span>
        </a>

        <nav class="pp-sidebar__nav">
            <div class="pp-sidebar__group">
                <span class="pp-sidebar__label">Main menu</span>

                <NavLink class="pp-nav-item" href="/dashboard" Match="NavLinkMatch.All">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                        <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                        <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                        <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.7" />
                    </svg>
                    <span>Dashboard</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/programmes">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 19V9m5 10V5m5 14v-7m5 7V8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    <span>Programmes</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/users">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.7" />
                        <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Users</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/notifications">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M10 19a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    <span>Notifications</span>
                    <span class="pp-sidebar__badge">7</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/reports">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                        <path d="M14 3v5h5" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                        <path d="M9 17v-3M12 17v-5M15 17v-2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    <span>Reports</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/analytics">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M5 20V13M12 20V4M19 20v-9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    <span>Analytics</span>
                </NavLink>
            </div>

            <div class="pp-sidebar__group">
                <span class="pp-sidebar__label">Preference</span>

                <NavLink class="pp-nav-item" href="/settings">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.7" />
                        <path d="M19.4 13a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-2.9 1.2V21a2 2 0 1 1-4 0v-.1A1.7 1.7 0 0 0 7 19.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0-1.2-2.9H3a2 2 0 1 1 0-4h.1A1.7 1.7 0 0 0 4.3 7l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1A1.7 1.7 0 0 0 10 5V4.9a2 2 0 1 1 4 0V5a1.7 1.7 0 0 0 2.9 1.2l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0 1.2 2.9H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1Z"
                              stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Settings</span>
                </NavLink>

                <NavLink class="pp-nav-item" href="/help">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
                        <path d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-.8.4-1 .9-1 1.7M12 17h.01"
                              stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    <span>Help centre</span>
                </NavLink>

                <button type="button" class="pp-nav-item" @onclick="HandleLogout">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 4h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-2M10 17l5-5-5-5M15 12H3"
                              stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>Log Out</span>
                </button>
            </div>
        </nav>

        @if (currentUser is not null)
        {
            <div class="pp-sidebar__user">
                <span class="pp-sidebar__avatar" aria-hidden="true">@Initials</span>
                <div class="pp-sidebar__user-meta">
                    <strong>@FullName</strong>
                    <span>@currentUser.Email</span>
                </div>
            </div>
        }
    </aside>

    <!-- ===== MAIN ===== -->
    <div class="pp-app__main">
        <header class="pp-topbar">
            <div class="pp-topbar__search">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7" />
                    <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                </svg>
                <input class="pp-input pp-input--icon" type="search" placeholder="Search here" aria-label="Search" />
            </div>

            <div class="pp-topbar__actions">
                <div class="pp-notif-wrap">
                    <button type="button" class="pp-iconbtn @(showNotifications ? "pp-iconbtn--active" : "")"
                            aria-label="Notifications" aria-haspopup="dialog" aria-expanded="@showNotifications"
                            @onclick="ToggleNotifications">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M10 19a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                        </svg>
                        <span class="pp-iconbtn__dot" aria-hidden="true"></span>
                    </button>

                    <NotificationsDialog Visible="showNotifications" OnClose="() => showNotifications = false" />
                </div>

                <span class="pp-datepill">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="5" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.7" />
                        <path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </span>
            </div>
        </header>

        <main class="pp-app__content">
            @Body
        </main>
    </div>
</div>

@code {
    // App shell for authenticated pages: persistent sidebar nav + topbar.
    // Distinct from the thin MarketingLayout used by public/marketing pages.

    private bool showNotifications;
    private bool loggingOut;

    private CurrentUserResponse? currentUser;

    private string FullName => $"{currentUser?.FirstName} {currentUser?.LastName}".Trim();

    private string Initials
    {
        get
        {
            var first = currentUser?.FirstName?.Trim();
            var last = currentUser?.LastName?.Trim();

            var initials = string.Concat(
                first is { Length: > 0 } ? first[0].ToString() : string.Empty,
                last is { Length: > 0 } ? last[0].ToString() : string.Empty);

            if (initials.Length == 0)
            {
                var email = currentUser?.Email?.Trim();
                initials = email is { Length: > 0 } ? email[0].ToString() : "?";
            }

            return initials.ToUpperInvariant();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // The dashboard is authenticated-only; a null result means no/expired session.
        currentUser = await AuthApi.GetCurrentUserAsync(CancellationToken.None);

        if (currentUser is null)
            Navigation.NavigateTo("/login");
    }

    private void ToggleNotifications() => showNotifications = !showNotifications;

    private async Task HandleLogout()
    {
        if (loggingOut)
            return;

        loggingOut = true;
        try
        {
            // Best-effort: server-side revocation/cookie clearing is idempotent, so head to
            // /login regardless of the outcome.
            await AuthApi.LogoutAsync(CancellationToken.None);
        }
        finally
        {
            Navigation.NavigateTo("/login");
        }
    }
}
