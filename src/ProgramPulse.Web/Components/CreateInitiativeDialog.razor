@using System.ComponentModel.DataAnnotations

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-create-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M3 7a2 2 0 0 1 2-2h4l2 2.5h6a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"
                              stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-create-title" class="pp-modal__title">Create New Initiative</h2>
                    <p class="pp-modal__subtitle">Create an initiative to structure your team's workflow.</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form-grid">
                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-init-name">Initiative name <span class="pp-req">*</span></label>
                        <InputText id="pp-init-name" @bind-Value="model.Name" class="pp-input" placeholder="Type here" />
                        <ValidationMessage For="() => model.Name" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-init-category">Initiative category <span class="pp-req">*</span></label>
                        <div class="pp-select">
                            <InputSelect id="pp-init-category" @bind-Value="model.Category" class="pp-input">
                                <option value="">Choose category</option>
                                @foreach (var category in Categories)
                                {
                                    <option value="@category">@category</option>
                                }
                            </InputSelect>
                            <svg class="pp-select__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </div>
                        <ValidationMessage For="() => model.Category" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-init-start">Start Date <span class="pp-req">*</span></label>
                        <InputDate id="pp-init-start" @bind-Value="model.StartDate" class="pp-input" />
                        <ValidationMessage For="() => model.StartDate" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-init-end">End Date <span class="pp-req">*</span></label>
                        <InputDate id="pp-init-end" @bind-Value="model.EndDate" class="pp-input" />
                        <ValidationMessage For="() => model.EndDate" class="pp-field__error" />
                    </div>
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-init-desc">Description</label>
                    <InputTextArea id="pp-init-desc" @bind-Value="model.Description" class="pp-input pp-input--area"
                                   placeholder="Enter the goals and scope for your initiative here" />
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label">Upload Documents</label>
                    <p class="pp-form__hint">Drop your initiative documents here to continue.</p>
                    <!-- Visual-only dropzone (no file handling yet) -->
                    <div class="pp-dropzone" aria-hidden="true">
                        <svg class="pp-dropzone__icon" viewBox="0 0 24 24" fill="none">
                            <path d="M7 18a4 4 0 0 1-.5-7.97A5.5 5.5 0 0 1 17.5 9 4.5 4.5 0 0 1 17 18"
                                  stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M12 12v6m0-6-2.5 2.5M12 12l2.5 2.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <p class="pp-dropzone__title">Choose a file or drag and drop it here.</p>
                        <p class="pp-dropzone__note">JPG or PDF file — up to 100MB</p>
                    </div>
                </div>

                @if (saved)
                {
                    <p class="pp-auth__ok">Initiative saved (demo) — backend not wired up yet.</p>
                }

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close">Cancel</button>
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="HandleSaveDraft">Save as Draft</button>
                    <button type="submit" class="pp-btn pp-btn--primary">Save Initiative</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private static readonly string[] Categories =
        ["Product", "Engineering", "Marketing", "Operations", "Sales", "Research"];

    private InitiativeModel model = new();
    private bool saved;

    private void HandleSave()
    {
        // TODO: POST model to /api/v1/initiatives once the WASM client is wired to the API
        // (needs API base URL config + CORS). For now this is a UI-only stub.
        saved = true;
    }

    private void HandleSaveDraft()
    {
        // TODO: persist as a draft initiative via the API. UI-only stub for now.
        saved = true;
    }

    private async Task Close()
    {
        saved = false;
        model = new();
        await OnClose.InvokeAsync();
    }

    private sealed class InitiativeModel
    {
        [Required(ErrorMessage = "Initiative name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please choose a category.")]
        public string Category { get; set; } = string.Empty;

        [Required(ErrorMessage = "Start date is required.")]
        public DateTime? StartDate { get; set; }

        [Required(ErrorMessage = "End date is required.")]
        public DateTime? EndDate { get; set; }

        public string? Description { get; set; }
    }
}
