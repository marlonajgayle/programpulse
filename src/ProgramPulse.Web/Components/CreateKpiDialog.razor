@using System.ComponentModel.DataAnnotations
@inject SampleData Data

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-kpi-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M4 19V5m0 14h16M8 15l3-4 3 3 4-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-kpi-title" class="pp-modal__title">Add KPI</h2>
                    <p class="pp-modal__subtitle">Define a key performance indicator for this objective.</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form-grid">
                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-name">KPI name <span class="pp-req">*</span></label>
                        <InputText id="pp-kpi-name" @bind-Value="model.Name" class="pp-input" placeholder="Type here" />
                        <ValidationMessage For="() => model.Name" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-unit">Unit <span class="pp-req">*</span></label>
                        <InputText id="pp-kpi-unit" @bind-Value="model.Unit" class="pp-input" placeholder="e.g. %, pts, days" />
                        <ValidationMessage For="() => model.Unit" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-direction">Direction <span class="pp-req">*</span></label>
                        <div class="pp-select">
                            <InputSelect id="pp-kpi-direction" @bind-Value="model.Direction" class="pp-input">
                                <option value="@KpiDirection.Increase">Increase</option>
                                <option value="@KpiDirection.Decrease">Decrease</option>
                            </InputSelect>
                            <svg class="pp-select__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </div>
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-due">Due date <span class="pp-req">*</span></label>
                        <InputDate id="pp-kpi-due" @bind-Value="model.DueDate" class="pp-input" />
                        <ValidationMessage For="() => model.DueDate" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-baseline">Baseline value <span class="pp-req">*</span></label>
                        <InputNumber id="pp-kpi-baseline" @bind-Value="model.Baseline" class="pp-input" placeholder="0" />
                        <ValidationMessage For="() => model.Baseline" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-target">Target value <span class="pp-req">*</span></label>
                        <InputNumber id="pp-kpi-target" @bind-Value="model.Target" class="pp-input" placeholder="0" />
                        <ValidationMessage For="() => model.Target" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-current">Current value</label>
                        <InputNumber id="pp-kpi-current" @bind-Value="model.Current" class="pp-input" placeholder="Defaults to baseline" />
                        <p class="pp-form__hint">Leave blank to start at the baseline.</p>
                    </div>
                </div>

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close">Cancel</button>
                    <button type="submit" class="pp-btn pp-btn--primary">Save KPI</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid InitiativeId { get; set; }
    [Parameter] public Guid ObjectiveId { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private KpiModel model = new();

    private async Task HandleSave()
    {
        Data.AddKpi(
            InitiativeId, ObjectiveId, model.Name, model.Unit, model.Direction,
            model.Baseline!.Value, model.Target!.Value, model.Current ?? model.Baseline!.Value,
            model.DueDate!.Value);

        await OnSaved.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        model = new();
        await OnClose.InvokeAsync();
    }

    private sealed class KpiModel
    {
        [Required(ErrorMessage = "KPI name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Unit is required.")]
        public string Unit { get; set; } = string.Empty;

        public KpiDirection Direction { get; set; } = KpiDirection.Increase;

        [Required(ErrorMessage = "Baseline value is required.")]
        public decimal? Baseline { get; set; }

        [Required(ErrorMessage = "Target value is required.")]
        public decimal? Target { get; set; }

        public decimal? Current { get; set; }

        [Required(ErrorMessage = "Due date is required.")]
        public DateTime? DueDate { get; set; }
    }
}
