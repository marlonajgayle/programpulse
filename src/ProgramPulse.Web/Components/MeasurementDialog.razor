@using System.ComponentModel.DataAnnotations
@inject SampleData Data

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-measure-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M4 19V5m0 14h16M8 15l3-4 3 3 4-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-measure-title" class="pp-modal__title">@(IsEdit ? "Edit measurement" : "Add measurement")</h2>
                    <p class="pp-modal__subtitle">@(Kpi is null ? "" : $"Record a value for {Kpi.Name} (in {Kpi.Unit}).")</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-measure-value">Value <span class="pp-req">*</span></label>
                    <InputNumber id="pp-measure-value" @bind-Value="model.Value" class="pp-input" placeholder="0" />
                    <ValidationMessage For="() => model.Value" class="pp-field__error" />
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-measure-notes">Notes</label>
                    <InputTextArea id="pp-measure-notes" @bind-Value="model.Notes" class="pp-input pp-input--area"
                                   placeholder="Optional context for this reading" />
                </div>

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close">Cancel</button>
                    <button type="submit" class="pp-btn pp-btn--primary">@(IsEdit ? "Save changes" : "Add measurement")</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid InitiativeId { get; set; }
    [Parameter] public Guid ObjectiveId { get; set; }
    [Parameter] public KpiVm? Kpi { get; set; }
    [Parameter] public MeasurementVm? Measurement { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private bool IsEdit => Measurement is not null;

    private MeasurementModel model = new();

    protected override void OnParametersSet()
    {
        if (Visible)
        {
            model = Measurement is { } measurement
                ? new MeasurementModel { Value = measurement.Value, Notes = measurement.Notes }
                : new MeasurementModel();
        }
    }

    private async Task HandleSave()
    {
        if (Kpi is null)
        {
            return;
        }

        if (Measurement is { } measurement)
        {
            Data.UpdateMeasurement(
                InitiativeId, ObjectiveId, Kpi.Id, measurement.Id, model.Value!.Value, model.Notes);
        }
        else
        {
            Data.AddMeasurement(InitiativeId, ObjectiveId, Kpi.Id, model.Value!.Value, model.Notes);
        }

        await OnSaved.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        model = new();
        await OnClose.InvokeAsync();
    }

    private sealed class MeasurementModel
    {
        [Required(ErrorMessage = "A value is required.")]
        public decimal? Value { get; set; }

        public string? Notes { get; set; }
    }
}
