@* Single initiative tile for the Initiatives grid.
   - AggregateStatus drives the pill (colour + shape icon).
   - The KPI status-mix bar is built from the real per-KPI statuses carried on the
     view model (Initiative.AllKpis) — no aggregate approximation.
   - Critical = the single worst initiative currently on screen; the page decides
     which one and gives it the dark treatment (at most one per view). *@

<article class="pp-card pp-init-card @(Critical ? "pp-init-card--critical" : null)"
         role="button" tabindex="0"
         @onclick="() => OnOpen.InvokeAsync(Initiative.Id)"
         @onkeydown="OnKey">
    <div class="pp-init-card__top">
        <h3 class="pp-init-card__name">@Initiative.Name</h3>
        <span class="pp-badge pp-badge--@StatusRollup.Modifier(Initiative.AggregateStatus)">
            <StatusIcon Status="Initiative.AggregateStatus" />
            @StatusRollup.Label(Initiative.AggregateStatus)
        </span>
    </div>

    <p class="pp-init-card__desc">@Initiative.Description</p>

    <div class="pp-init-card__meta">
        <div class="pp-kpi-bar" role="img" aria-label="@BarLabel">
            @if (_kpis.Count == 0)
            {
                <span class="pp-kpi-bar__seg pp-kpi-bar__seg--idle"></span>
            }
            else
            {
                @foreach (var kpi in _ordered)
                {
                    <span class="pp-kpi-bar__seg pp-kpi-bar__seg--@StatusRollup.Modifier(kpi.Status)"></span>
                }
            }
        </div>

        <div class="pp-init-card__foot">
            <span class="pp-meta__item">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.7" />
                    <path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                </svg>
                @DateRange
            </span>
            <span class="pp-init-card__counts">
                <span>@Initiative.ObjectiveCount @(Initiative.ObjectiveCount == 1 ? "objective" : "objectives")</span>
                <span class="pp-dot-sep">·</span>
                <span>@Initiative.KpiCount @(Initiative.KpiCount == 1 ? "KPI" : "KPIs")</span>
            </span>
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public InitiativeVm Initiative { get; set; } = default!;

    /// <summary>Give this card the dark "most critical" treatment. At most one per view.</summary>
    [Parameter] public bool Critical { get; set; }

    [Parameter] public EventCallback<Guid> OnOpen { get; set; }

    // Worst-first so the bar reads danger → healthy left-to-right.
    private static readonly KpiStatus[] StatusOrder =
    {
        KpiStatus.OffTrack, KpiStatus.AtRisk, KpiStatus.OnTrack,
        KpiStatus.Completed, KpiStatus.NotStarted,
    };

    private IReadOnlyList<KpiVm> _kpis = Array.Empty<KpiVm>();
    private IReadOnlyList<KpiVm> _ordered = Array.Empty<KpiVm>();

    protected override void OnParametersSet()
    {
        _kpis = Initiative.AllKpis.ToList();
        _ordered = _kpis.OrderBy(k => Array.IndexOf(StatusOrder, k.Status)).ToList();
    }

    private string DateRange =>
        Initiative.EndDate is { } end
            ? $"{Initiative.StartDate:MMM yyyy} – {end:MMM yyyy}"
            : $"{Initiative.StartDate:MMM yyyy} – ongoing";

    private string BarLabel
    {
        get
        {
            if (_kpis.Count == 0)
            {
                return "No KPIs yet";
            }

            var parts = _kpis
                .GroupBy(k => k.Status)
                .OrderBy(g => Array.IndexOf(StatusOrder, g.Key))
                .Select(g => $"{g.Count()} {StatusRollup.Label(g.Key).ToLowerInvariant()}");
            return $"KPI status: {string.Join(", ", parts)}";
        }
    }

    private Task OnKey(KeyboardEventArgs e) =>
        e.Key is "Enter" or " " ? OnOpen.InvokeAsync(Initiative.Id) : Task.CompletedTask;
}
