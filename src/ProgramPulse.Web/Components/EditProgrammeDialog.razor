@using System.ComponentModel.DataAnnotations
@inject ProgrammesApiClient ProgrammesApi

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-edit-init-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M3 7a2 2 0 0 1 2-2h4l2 2.5h6a2 2 0 0 1 2 2V17a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"
                              stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-edit-init-title" class="pp-modal__title">Edit Programme</h2>
                    <p class="pp-modal__subtitle">Update the details of this programme.</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form-grid">
                    <div class="pp-form__field pp-form__field--full">
                        <label class="pp-form__label" for="pp-edit-init-name">Programme name <span class="pp-req">*</span></label>
                        <InputText id="pp-edit-init-name" @bind-Value="model.Name" class="pp-input" placeholder="Type here" />
                        <ValidationMessage For="() => model.Name" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-edit-init-start">Start Date</label>
                        <InputDate id="pp-edit-init-start" @bind-Value="model.StartDate" class="pp-input" />
                        <ValidationMessage For="() => model.StartDate" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-edit-init-end">End Date</label>
                        <InputDate id="pp-edit-init-end" @bind-Value="model.EndDate" class="pp-input" />
                        <ValidationMessage For="() => model.EndDate" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field pp-form__field--full">
                        <label class="pp-form__label" for="pp-edit-init-parent">Parent programme</label>
                        @if (_hasSubProgrammes)
                        {
                            <p class="pp-form__hint">This programme has sub-programmes, so it stays top-level.</p>
                        }
                        else
                        {
                            <InputSelect id="pp-edit-init-parent" @bind-Value="model.ParentProgrammeId" class="pp-input">
                                <option value="">None (top-level programme)</option>
                                @foreach (var option in _parentOptions)
                                {
                                    <option value="@option.Id">@option.Name</option>
                                }
                            </InputSelect>
                            <p class="pp-form__hint">Nest this under an existing programme, or leave as top-level.</p>
                        }
                    </div>
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-edit-init-desc">Description <span class="pp-req">*</span></label>
                    <InputTextArea id="pp-edit-init-desc" @bind-Value="model.Description" class="pp-input pp-input--area"
                                   placeholder="Enter the goals and scope for your programme here" />
                    <ValidationMessage For="() => model.Description" class="pp-field__error" />
                </div>

                @if (_error is not null)
                {
                    <p class="pp-auth__error">@_error</p>
                }

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close" disabled="@_saving">Cancel</button>
                    <button type="submit" class="pp-btn pp-btn--primary" disabled="@_saving">
                        @(_saving ? "Saving…" : "Save changes")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public ProgrammeVm? Programme { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ProgrammeModel model = new();
    private IReadOnlyList<(Guid Id, string Name)> _parentOptions = Array.Empty<(Guid, string)>();
    private bool _hasSubProgrammes;
    private Guid? _loadedForId;
    private bool _saving;
    private string? _error;

    // Re-initialise the form (and fetch parent options) when a new programme is opened.
    protected override async Task OnParametersSetAsync()
    {
        if (Visible && Programme is { } programme && _loadedForId != programme.Id)
        {
            _loadedForId = programme.Id;
            model = new ProgrammeModel
            {
                Name = programme.Name,
                Description = programme.Description,
                StartDate = programme.StartDate,
                EndDate = programme.EndDate,
                ParentProgrammeId = programme.ParentProgrammeId,
            };

            // A programme with its own sub-programmes can't become a child (max two levels),
            // so the parent selector is hidden for it.
            _hasSubProgrammes = programme.Children.Count > 0;

            if (_hasSubProgrammes)
            {
                _parentOptions = Array.Empty<(Guid, string)>();
            }
            else
            {
                var page = await ProgrammesApi.GetProgrammesAsync(1, 200, CancellationToken.None);
                _parentOptions = page?.Items
                    .Where(p => p.Id != programme.Id)
                    .Select(p => (p.Id, p.Name)).ToList()
                    ?? (IReadOnlyList<(Guid, string)>)Array.Empty<(Guid, string)>();
            }
        }
    }

    private async Task HandleSave()
    {
        if (Programme is null)
        {
            return;
        }

        _saving = true;
        _error = null;

        var request = new UpdateProgrammeRequest(
            model.Name, model.Description ?? string.Empty, model.StartDate, model.EndDate,
            model.ParentProgrammeId);
        var result = await ProgrammesApi.UpdateProgrammeAsync(Programme.Id, request, CancellationToken.None);
        _saving = false;

        if (!result.Success)
        {
            _error = result.GeneralError ?? "Couldn't save the programme. Please try again.";
            return;
        }

        await OnSaved.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        _error = null;
        _saving = false;
        model = new();
        _loadedForId = null;
        await OnClose.InvokeAsync();
    }

    private sealed class ProgrammeModel : IValidatableObject
    {
        [Required(ErrorMessage = "Programme name is required.")]
        public string Name { get; set; } = string.Empty;

        public DateTime? StartDate { get; set; }

        public DateTime? EndDate { get; set; }

        [Required(ErrorMessage = "A description is required.")]
        public string? Description { get; set; }

        public Guid? ParentProgrammeId { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (StartDate.HasValue && EndDate.HasValue && EndDate < StartDate)
            {
                yield return new ValidationResult(
                    "The end date cannot be earlier than the start date.", [nameof(EndDate)]);
            }
        }
    }
}
