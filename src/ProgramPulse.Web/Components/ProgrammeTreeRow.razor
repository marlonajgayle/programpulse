@* The clickable body of a hierarchy row (used for both a parent programme and its
   sub-programmes). The expand/collapse chevron lives in the parent page; this renders
   everything to the right of it. Clicking the body opens the detail page; the edit
   button stops propagation so it doesn't also navigate. *@

<div class="pp-tree__main" role="button" tabindex="0"
     @onclick="() => OnOpen.InvokeAsync(Programme.Id)"
     @onkeydown="OnKey">
    <div class="pp-tree__title">
        <h3 class="pp-tree__name">@Programme.Name</h3>
        @if (!IsChild && Programme.Children.Count > 0)
        {
            <span class="pp-tree__count">
                @Programme.Children.Count sub-@(Programme.Children.Count == 1 ? "programme" : "programmes")
            </span>
        }
    </div>

    <div class="pp-tree__meta">
        <span class="pp-badge pp-badge--@LifecycleModifier">@Programme.LifecycleStatusLabel</span>
        <span class="pp-tree__metaitem">@Programme.ObjectiveCount obj · @Programme.KpiCount KPI</span>
        <span class="pp-tree__metaitem pp-tree__metaitem--muted">@DeadlineText</span>
        <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Edit programme"
                @onclick="() => OnEdit.InvokeAsync(Programme)" @onclick:stopPropagation="true">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4 20h4l10-10-4-4L4 16v4Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                <path d="m13.5 6.5 4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ProgrammeVm Programme { get; set; } = default!;

    /// <summary>Child rows omit the sub-programme count chip.</summary>
    [Parameter] public bool IsChild { get; set; }

    [Parameter] public EventCallback<Guid> OnOpen { get; set; }
    [Parameter] public EventCallback<ProgrammeVm> OnEdit { get; set; }

    private string DeadlineText =>
        Programme.EndDate is { } end ? end.ToString("MMM d, yyyy") : "Ongoing";

    private string LifecycleModifier =>
        Programme.LifecycleStatus == ProgrammeStatus.Active ? "track" : "idle";

    private Task OnKey(KeyboardEventArgs e) =>
        e.Key is "Enter" or " " ? OnOpen.InvokeAsync(Programme.Id) : Task.CompletedTask;
}
