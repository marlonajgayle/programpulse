@using System.ComponentModel.DataAnnotations
@inject MeasurementCommentsApiClient CommentsApi

@if (Visible && Measurement is { } measurement)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-comments-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M4 5h16v11H8l-4 4V5Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-comments-title" class="pp-modal__title">Comments</h2>
                    <p class="pp-modal__subtitle">Reading of @Fmt(measurement.Value) on @measurement.MeasurementDate.ToString("d MMM yyyy")</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Comment list ===== -->
            @if (_loading)
            {
                <p class="pp-vtimeline__empty">Loading comments…</p>
            }
            else if (_comments.Count == 0)
            {
                <p class="pp-vtimeline__empty">No comments yet. Add the first one below.</p>
            }
            else
            {
                <ul class="pp-commentlist">
                    @foreach (var comment in _comments)
                    {
                        <li class="pp-commentlist__item">
                            <p class="pp-commentlist__text">@comment.Text</p>
                            <span class="pp-commentlist__meta">@comment.CreatedBy · @comment.CreatedDate.ToString("d MMM yyyy")</span>
                        </li>
                    }
                </ul>
            }

            <!-- ===== Add comment ===== -->
            <EditForm Model="model" OnValidSubmit="HandleAdd">
                <DataAnnotationsValidator />

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-comment-text">Add a comment</label>
                    <InputTextArea id="pp-comment-text" @bind-Value="model.Text" class="pp-input pp-input--area"
                                   placeholder="Share context on this reading" />
                    <ValidationMessage For="() => model.Text" class="pp-field__error" />
                </div>

                @if (_error is not null)
                {
                    <p class="pp-auth__error">@_error</p>
                }

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close" disabled="@_saving">Close</button>
                    <button type="submit" class="pp-btn pp-btn--primary" disabled="@_saving">
                        @(_saving ? "Adding…" : "Add comment")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public MeasurementVm? Measurement { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private CommentModel model = new();
    private IReadOnlyList<MeasurementCommentResponse> _comments = [];
    private Guid _loadedFor;
    private bool _loading;
    private bool _saving;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        // Load the measurement's comments once when the dialog opens for it.
        if (Visible && Measurement is { } measurement && _loadedFor != measurement.Id)
        {
            _loadedFor = measurement.Id;
            model = new CommentModel();
            _error = null;
            await LoadCommentsAsync(measurement.Id);
        }
    }

    private async Task LoadCommentsAsync(Guid measurementId)
    {
        _loading = true;
        _comments = await CommentsApi.GetCommentsAsync(measurementId, CancellationToken.None) ?? [];
        _loading = false;
    }

    private async Task HandleAdd()
    {
        if (Measurement is not { } measurement)
        {
            return;
        }

        _saving = true;
        _error = null;

        var result = await CommentsApi.AddCommentAsync(
            measurement.Id, new CreateCommentRequest(model.Text!), CancellationToken.None);

        if (!result.Success)
        {
            _saving = false;
            _error = result.GeneralError ?? "Couldn't add the comment. Please try again.";
            return;
        }

        // Show the new comment immediately, then let the parent reload so the timeline count updates.
        model = new CommentModel();
        await LoadCommentsAsync(measurement.Id);
        _saving = false;
        await OnSaved.InvokeAsync();
    }

    private async Task Close()
    {
        _error = null;
        _saving = false;
        model = new CommentModel();
        _comments = [];
        _loadedFor = Guid.Empty;
        await OnClose.InvokeAsync();
    }

    private static string Fmt(decimal value) =>
        value == Math.Truncate(value) ? value.ToString("0") : value.ToString("0.##");

    private sealed class CommentModel
    {
        [Required(ErrorMessage = "A comment is required.")]
        [MaxLength(2000, ErrorMessage = "Comments can be at most 2000 characters.")]
        public string? Text { get; set; }
    }
}
