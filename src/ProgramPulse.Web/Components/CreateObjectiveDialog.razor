@using System.ComponentModel.DataAnnotations
@inject ObjectivesApiClient ObjectivesApi

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-obj-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-obj-title" class="pp-modal__title">Add Objective</h2>
                    <p class="pp-modal__subtitle">Add a measurable objective to this programme.</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-obj-name">Objective name <span class="pp-req">*</span></label>
                    <InputText id="pp-obj-name" @bind-Value="model.Name" class="pp-input" placeholder="Type here" />
                    <ValidationMessage For="() => model.Name" class="pp-field__error" />
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-obj-desc">Description <span class="pp-req">*</span></label>
                    <InputTextArea id="pp-obj-desc" @bind-Value="model.Description" class="pp-input pp-input--area"
                                   placeholder="Describe what this objective aims to achieve" />
                    <ValidationMessage For="() => model.Description" class="pp-field__error" />
                </div>

                <hr class="pp-modal__rule" />
                <h3 class="pp-section-head">Key performance indicator</h3>
                <p class="pp-modal__subtitle">Every objective is measured by exactly one KPI.</p>

                <div class="pp-form-grid">
                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-name">KPI name <span class="pp-req">*</span></label>
                        <InputText id="pp-kpi-name" @bind-Value="model.KpiName" class="pp-input" placeholder="Type here" />
                        <ValidationMessage For="() => model.KpiName" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-unit">Unit <span class="pp-req">*</span></label>
                        <InputText id="pp-kpi-unit" @bind-Value="model.KpiUnit" class="pp-input" placeholder="e.g. %, pts, days" />
                        <ValidationMessage For="() => model.KpiUnit" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-direction">Direction <span class="pp-req">*</span></label>
                        <div class="pp-select">
                            <InputSelect id="pp-kpi-direction" @bind-Value="model.Direction" class="pp-input">
                                <option value="@KpiDirection.Increase">Increase</option>
                                <option value="@KpiDirection.Decrease">Decrease</option>
                            </InputSelect>
                            <svg class="pp-select__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </div>
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-due">Due date <span class="pp-req">*</span></label>
                        <InputDate id="pp-kpi-due" @bind-Value="model.DueDate" class="pp-input" />
                        <ValidationMessage For="() => model.DueDate" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-baseline">Baseline value <span class="pp-req">*</span></label>
                        <InputNumber id="pp-kpi-baseline" @bind-Value="model.Baseline" class="pp-input" placeholder="0" />
                        <ValidationMessage For="() => model.Baseline" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-target">Target value <span class="pp-req">*</span></label>
                        <InputNumber id="pp-kpi-target" @bind-Value="model.Target" class="pp-input" placeholder="0" />
                        <ValidationMessage For="() => model.Target" class="pp-field__error" />
                    </div>

                    <div class="pp-form__field">
                        <label class="pp-form__label" for="pp-kpi-current">Current value</label>
                        <InputNumber id="pp-kpi-current" @bind-Value="model.Current" class="pp-input" placeholder="Defaults to baseline" />
                        <p class="pp-form__hint">Leave blank to start at the baseline.</p>
                    </div>
                </div>

                @if (_error is not null)
                {
                    <p class="pp-auth__error">@_error</p>
                }

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close" disabled="@_saving">Cancel</button>
                    <button type="submit" class="pp-btn pp-btn--primary" disabled="@_saving">
                        @(_saving ? "Saving…" : "Save Objective")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProgrammeId { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ObjectiveModel model = new();
    private bool _saving;
    private string? _error;

    private async Task HandleSave()
    {
        _saving = true;
        _error = null;

        var request = new CreateObjectiveRequest(
            model.Name,
            model.Description ?? string.Empty,
            new CreateObjectiveKpiRequest(
                model.KpiName,
                model.KpiUnit,
                model.Direction,
                model.Baseline!.Value,
                model.Target!.Value,
                model.Current ?? model.Baseline!.Value,
                model.DueDate!.Value));
        var result = await ObjectivesApi.CreateObjectiveAsync(ProgrammeId, request, CancellationToken.None);
        _saving = false;

        if (!result.Success)
        {
            _error = result.GeneralError ?? "Couldn't add the objective. Please try again.";
            return;
        }

        await OnSaved.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        _error = null;
        _saving = false;
        model = new();
        await OnClose.InvokeAsync();
    }

    private sealed class ObjectiveModel
    {
        [Required(ErrorMessage = "Objective name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "A description is required.")]
        public string? Description { get; set; }

        [Required(ErrorMessage = "KPI name is required.")]
        public string KpiName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Unit is required.")]
        public string KpiUnit { get; set; } = string.Empty;

        public KpiDirection Direction { get; set; } = KpiDirection.Increase;

        [Required(ErrorMessage = "Baseline value is required.")]
        public decimal? Baseline { get; set; }

        [Required(ErrorMessage = "Target value is required.")]
        public decimal? Target { get; set; }

        public decimal? Current { get; set; }

        [Required(ErrorMessage = "Due date is required.")]
        public DateTime? DueDate { get; set; }
    }
}
