@using System.ComponentModel.DataAnnotations
@inject ObjectivesApiClient ObjectivesApi

@if (Visible)
{
    <div class="pp-modal" @onclick="Close">
        <div class="pp-modal__dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="pp-obj-title">
            <!-- ===== Header ===== -->
            <div class="pp-modal__head">
                <span class="pp-modal__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <div class="pp-modal__heading">
                    <h2 id="pp-obj-title" class="pp-modal__title">Add Objective</h2>
                    <p class="pp-modal__subtitle">Add a measurable objective to this programme.</p>
                </div>
                <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Close dialog" @onclick="Close">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                </button>
            </div>

            <hr class="pp-modal__rule" />

            <!-- ===== Body ===== -->
            <EditForm Model="model" OnValidSubmit="HandleSave">
                <DataAnnotationsValidator />

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-obj-name">Objective name <span class="pp-req">*</span></label>
                    <InputText id="pp-obj-name" @bind-Value="model.Name" class="pp-input" placeholder="Type here" />
                    <ValidationMessage For="() => model.Name" class="pp-field__error" />
                </div>

                <div class="pp-form__field pp-form__field--full">
                    <label class="pp-form__label" for="pp-obj-desc">Description <span class="pp-req">*</span></label>
                    <InputTextArea id="pp-obj-desc" @bind-Value="model.Description" class="pp-input pp-input--area"
                                   placeholder="Describe what this objective aims to achieve" />
                    <ValidationMessage For="() => model.Description" class="pp-field__error" />
                </div>

                @if (_error is not null)
                {
                    <p class="pp-auth__error">@_error</p>
                }

                <!-- ===== Footer ===== -->
                <div class="pp-modal__foot">
                    <button type="button" class="pp-btn pp-btn--ghost" @onclick="Close" disabled="@_saving">Cancel</button>
                    <button type="submit" class="pp-btn pp-btn--primary" disabled="@_saving">
                        @(_saving ? "Saving…" : "Save Objective")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProgrammeId { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ObjectiveModel model = new();
    private bool _saving;
    private string? _error;

    private async Task HandleSave()
    {
        _saving = true;
        _error = null;

        var request = new CreateObjectiveRequest(model.Name, model.Description ?? string.Empty);
        var result = await ObjectivesApi.CreateObjectiveAsync(ProgrammeId, request, CancellationToken.None);
        _saving = false;

        if (!result.Success)
        {
            _error = result.GeneralError ?? "Couldn't add the objective. Please try again.";
            return;
        }

        await OnSaved.InvokeAsync();
        await Close();
    }

    private async Task Close()
    {
        _error = null;
        _saving = false;
        model = new();
        await OnClose.InvokeAsync();
    }

    private sealed class ObjectiveModel
    {
        [Required(ErrorMessage = "Objective name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "A description is required.")]
        public string? Description { get; set; }
    }
}
