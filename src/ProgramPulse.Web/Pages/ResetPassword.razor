@page "/reset-password"
@layout MarketingLayout
@using System.ComponentModel.DataAnnotations
@inject AuthApiClient AuthApi
@inject NavigationManager Navigation

<PageTitle>Set a new password — ProgramPulse</PageTitle>

<div class="pp-auth">
    <!-- ===== LEFT: brand panel ===== -->
    <aside class="pp-auth__art" aria-hidden="true">
        <div class="pp-auth__art-top">
            <span class="pp-logo__text pp-auth__brand">Program<span class="pp-auth__brand-accent">Pulse</span></span>
        </div>

        <div class="pp-auth__art-center">
            <svg class="pp-ekg" viewBox="0 0 600 220" preserveAspectRatio="none">
                <line x1="0" y1="110" x2="600" y2="110" class="pp-auth__baseline" />
                <path class="pp-auth__trace"
                      d="M0,110 L90,110 L108,70 L122,150 L140,110 L230,110
                         L250,60 L268,160 L286,110 L380,110 L398,40 L418,180
                         L436,110 L520,110 L540,30 L560,190 L578,110 L600,110"
                      fill="none" stroke="#ffffff" stroke-width="3"
                      stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>

        <div class="pp-auth__art-bottom">
            <span class="pp-auth__badge">Trusted by 2,800+ teams</span>
            <p class="pp-auth__tagline">
                Track every programme's pulse — on track, at risk, and off track
                stop being opinions and start being signals.
            </p>
        </div>
    </aside>

    <!-- ===== RIGHT: form panel ===== -->
    <section class="pp-auth__panel">
        <div class="pp-auth__form">
            <h1 class="pp-auth__title">Set a new password</h1>
            <p class="pp-auth__subtitle">Choose a strong password to secure your account.</p>

            <EditForm Model="model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="pp-field">
                    <svg class="pp-field__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.8" />
                        <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                    <InputText @bind-Value="model.NewPassword" type="password" class="pp-input pp-input--icon"
                               placeholder="Enter a new password" autocomplete="new-password" aria-label="New password" />
                </div>
                <ValidationMessage For="() => model.NewPassword" class="pp-field__error" />

                <div class="pp-field">
                    <svg class="pp-field__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.8" />
                        <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                    <InputText @bind-Value="model.ConfirmPassword" type="password" class="pp-input pp-input--icon"
                               placeholder="Confirm your password" autocomplete="new-password" aria-label="Confirm password" />
                </div>
                <ValidationMessage For="() => model.ConfirmPassword" class="pp-field__error" />

                @if (!string.IsNullOrEmpty(generalError))
                {
                    <p class="pp-field__error" role="alert">@generalError</p>
                }

                <button type="submit" class="pp-btn pp-btn--primary pp-btn--block pp-btn--lg pp-auth__submit" disabled="@busy">
                    @(busy ? "Resetting…" : "Reset password")
                </button>
            </EditForm>

            <p class="pp-auth__signup">
                <a href="/login" class="pp-auth__link">← Back to log in</a>
            </p>
        </div>
    </section>
</div>

@code {
    private readonly ResetPasswordModel model = new();
    private bool busy;
    private string? generalError;

    protected override void OnInitialized()
    {
        // The API emails a link of the form /reset-password?email=...&token=...
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = uri.Query.TrimStart('?');

        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            var value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1]) : string.Empty;

            if (string.Equals(key, "email", StringComparison.OrdinalIgnoreCase))
            {
                model.Email = value;
            }
            else if (string.Equals(key, "token", StringComparison.OrdinalIgnoreCase))
            {
                model.Token = value;
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (busy)
            return;

        generalError = null;

        // The page is reachable only via the emailed link; without a token there is nothing to reset.
        if (string.IsNullOrWhiteSpace(model.Token) || string.IsNullOrWhiteSpace(model.Email))
        {
            generalError = "This reset link is invalid or has expired. Request a new one.";
            return;
        }

        busy = true;

        try
        {
            var result = await AuthApi.ResetPasswordAsync(
                new ResetPasswordRequest(model.Email, model.Token, model.NewPassword, model.ConfirmPassword),
                CancellationToken.None);

            if (result.Success)
            {
                Navigation.NavigateTo("/login?reset=1");
                return;
            }

            // Invalid/expired token and weak-password errors come back as ProblemDetails.
            generalError = result.GeneralError ?? "Unable to reset your password. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private sealed class ResetPasswordModel
    {
        public string Email { get; set; } = string.Empty;

        public string Token { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
