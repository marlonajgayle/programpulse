@page "/initiatives"
@layout DashboardLayout
@inject SampleData Data
@inject NavigationManager Nav

<PageTitle>Initiatives — ProgramPulse</PageTitle>

<div class="pp-page__head">
    <div>
        <h1 class="pp-dash__heading">Initiatives</h1>
        <p class="pp-page__subtitle">@_all.Count active @(_all.Count == 1 ? "initiative" : "initiatives") across your programme.</p>
    </div>
    <button type="button" class="pp-btn pp-btn--primary" @onclick="() => showCreate = true">
        <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        New initiative
    </button>
</div>

<div class="pp-toolbar">
    <div class="pp-topbar__search pp-toolbar__search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7" />
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
        </svg>
        <input class="pp-input pp-input--icon" type="search" placeholder="Filter initiatives"
               aria-label="Filter initiatives" value="@_search"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty" />
    </div>
    <div class="pp-legend pp-legend--filter" role="group" aria-label="Filter by status">
        @foreach (var opt in FilterOptions)
        {
            var active = _activeFilters.Contains(opt.Status);
            <button type="button"
                    class="pp-legend__chip pp-legend__chip--@opt.Modifier @(active ? "is-active" : null)"
                    aria-pressed="@active"
                    @onclick="() => ToggleFilter(opt.Status)">
                <StatusIcon Status="opt.Status" />
                @opt.Label
            </button>
        }
    </div>
</div>

@if (_all.Count == 0)
{
    <div class="pp-empty">
        <p class="pp-empty__title">No initiatives yet</p>
        <p class="pp-empty__note">Create your first initiative to start tracking objectives and KPIs.</p>
    </div>
}
else
{
    var visible = Filtered();
    var criticalId = MostCriticalId(visible);

    @if (visible.Count == 0)
    {
        <div class="pp-empty">
            <p class="pp-empty__title">No initiatives match your filters</p>
            <p class="pp-empty__note">Try a different search term or status filter.</p>
            <button type="button" class="pp-btn pp-btn--ghost" @onclick="ClearFilters">Clear filters</button>
        </div>
    }
    else
    {
        <div class="pp-list-grid">
            @foreach (var initiative in visible)
            {
                <InitiativeCard Initiative="initiative"
                                Critical="initiative.Id == criticalId"
                                OnOpen="Open" />
            }
        </div>
    }
}

<CreateInitiativeDialog Visible="showCreate" OnClose="() => showCreate = false" />

@code {
    private IReadOnlyList<InitiativeVm> _all = Array.Empty<InitiativeVm>();
    private readonly HashSet<KpiStatus> _activeFilters = new();
    private string _search = string.Empty;
    private bool showCreate;

    // Legend chips double as status filters. Only the three "live" statuses are offered;
    // completed/not-started initiatives simply fall outside an active status filter.
    private static readonly (KpiStatus Status, string Modifier, string Label)[] FilterOptions =
    {
        (KpiStatus.OnTrack, "track", "On track"),
        (KpiStatus.AtRisk, "warn", "At risk"),
        (KpiStatus.OffTrack, "off", "Off track"),
    };

    protected override void OnInitialized() => _all = Data.GetInitiatives();

    private void Open(Guid id) => Nav.NavigateTo($"/initiatives/{id}");

    private void ToggleFilter(KpiStatus status)
    {
        if (!_activeFilters.Remove(status))
        {
            _activeFilters.Add(status);
        }
    }

    private void ClearFilters()
    {
        _activeFilters.Clear();
        _search = string.Empty;
    }

    // Status filter and free-text search combine with AND.
    private IReadOnlyList<InitiativeVm> Filtered()
    {
        IEnumerable<InitiativeVm> query = _all;

        if (_activeFilters.Count > 0)
        {
            query = query.Where(i => _activeFilters.Contains(i.AggregateStatus));
        }

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var term = _search.Trim();
            query = query.Where(i =>
                i.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                || i.Description.Contains(term, StringComparison.OrdinalIgnoreCase));
        }

        return query.ToList();
    }

    // The single worst initiative among those currently on screen, or null if none is
    // at-risk-or-worse (so an all-healthy board gets no dark card). Ranking:
    // off-track beats at-risk, ties broken by off-track KPI count, then soonest end date.
    private static Guid? MostCriticalId(IReadOnlyList<InitiativeVm> visible) =>
        visible
            .Where(i => i.AggregateStatus is KpiStatus.OffTrack or KpiStatus.AtRisk)
            .OrderByDescending(i => i.AggregateStatus == KpiStatus.OffTrack)
            .ThenByDescending(i => i.AllKpis.Count(k => k.Status == KpiStatus.OffTrack))
            .ThenBy(i => i.EndDate ?? DateTime.MaxValue)
            .Select(i => (Guid?)i.Id)
            .FirstOrDefault();
}
