@page "/initiatives/{Id:guid}/objectives/{ObjectiveId:guid}"
@layout DashboardLayout
@inject SampleData Data

<PageTitle>@(objective?.Name ?? "Objective") — ProgramPulse</PageTitle>

@if (initiative is null || objective is null)
{
    <nav class="pp-crumbs" aria-label="Breadcrumb">
        <a href="/initiatives">Initiatives</a>
        <span class="pp-crumbs__sep">/</span>
        <span class="pp-crumbs__current">Not found</span>
    </nav>
    <div class="pp-empty">
        <p class="pp-empty__title">Objective not found</p>
        <p class="pp-empty__note">It may have been removed. Head back to the <a class="pp-auth__link" href="/initiatives">initiatives list</a>.</p>
    </div>
}
else
{
    <nav class="pp-crumbs" aria-label="Breadcrumb">
        <a href="/initiatives">Initiatives</a>
        <span class="pp-crumbs__sep">/</span>
        <a href="/initiatives/@initiative.Id">@initiative.Name</a>
        <span class="pp-crumbs__sep">/</span>
        <span class="pp-crumbs__current">@objective.Name</span>
    </nav>

    <header class="pp-detail__head">
        <div class="pp-detail__title-row">
            <h1 class="pp-dash__heading">@objective.Name</h1>
            <span class="pp-badge pp-badge--@StatusRollup.Modifier(objective.AggregateStatus)">
                @StatusRollup.Label(objective.AggregateStatus)
            </span>
            <button type="button" class="pp-btn pp-btn--ghost" @onclick="() => showEditObjective = true">
                <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
                    <path d="M4 20h4l10-10a2.1 2.1 0 0 0-3-3L5 17v3Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Edit
            </button>
        </div>
        <p class="pp-detail__desc">@objective.Description</p>
    </header>

    <div class="pp-section-head-row">
        <h2 class="pp-section-head">Key performance indicators</h2>
        <button type="button" class="pp-btn pp-btn--primary" @onclick="() => showCreateKpi = true">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Add KPI
        </button>
    </div>

    @if (objective.Kpis.Count == 0)
    {
        <div class="pp-empty">
            <p class="pp-empty__title">No KPIs yet</p>
            <p class="pp-empty__note">This objective has no measurable indicators defined.</p>
        </div>
    }
    else
    {
        <div class="pp-kpi-grid">
            @foreach (var kpi in objective.Kpis)
            {
                <article class="pp-card pp-kpi-card">
                    <span class="pp-kpi-card__stripe pp-kpi-card__stripe--@kpi.StatusModifier" aria-hidden="true"></span>

                    <div class="pp-kpi-card__head">
                        <h3 class="pp-kpi-card__name">@kpi.Name</h3>
                        <div class="pp-kpi-card__head-actions">
                            <span class="pp-badge pp-badge--@kpi.StatusModifier">@kpi.StatusLabel</span>
                            <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Edit KPI" @onclick="() => editingKpi = kpi">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M4 20h4l10-10a2.1 2.1 0 0 0-3-3L5 17v3Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="pp-kpi-card__meta">
                        <span class="pp-kpi-card__unit">Measured in @kpi.Unit</span>
                        <span class="pp-dot-sep" aria-hidden="true">·</span>
                        <span class="pp-kpi-card__recency @(kpi.IsMeasurementOverdue ? "pp-kpi-card__recency--warn" : "")">
                            @if (kpi.IsMeasurementOverdue)
                            {
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M12 3 2 20h20L12 3Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                                    <path d="M12 10v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                                    <circle cx="12" cy="17" r="1" fill="currentColor" />
                                </svg>
                            }
                            @RecencyLabel(kpi)
                        </span>
                    </div>

                    <div class="pp-kpi-card__chips">
                        <span class="pp-chip">
                            @if (kpi.Direction == KpiDirection.Increase)
                            {
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 19 19 5M19 5h-7M19 5v7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 5 19 19M19 19h-7M19 19v-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            }
                            @kpi.DirectionLabel
                        </span>
                        <span class="pp-chip @(string.IsNullOrEmpty(kpi.DueChipModifier) ? "" : $"pp-chip--{kpi.DueChipModifier}")">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.7" />
                                <path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Due @kpi.DueDate.ToString("d MMM yyyy")@(kpi.IsOverdue ? " · overdue" : "")
                        </span>
                    </div>

                    <!-- Measurement trend (glance-level, no axes/labels) -->
                    @if (kpi.RecentMeasurementValues.Count >= 2)
                    {
                        var spark = BuildSparkline(kpi.RecentMeasurementValues);
                        <svg class="pp-spark" viewBox="0 0 250 44" preserveAspectRatio="none" role="img"
                             aria-label="Recent measurement trend for @kpi.Name">
                            <polyline class="pp-spark__line pp-spark__line--@kpi.StatusModifier" points="@spark.Points" />
                            <circle class="pp-spark__dot pp-spark__dot--@kpi.StatusModifier"
                                    cx="@spark.LastX.ToString("0.#", Culture)" cy="@spark.LastY.ToString("0.#", Culture)" r="3" />
                        </svg>
                    }
                    else
                    {
                        <p class="pp-spark__empty">Not enough data yet for a trend</p>
                    }

                    <!-- Progress: baseline -> current -> target -->
                    <div class="pp-progress">
                        <div class="pp-progress__track">
                            <div class="pp-progress__fill pp-progress__fill--@kpi.StatusModifier" style="width:@(kpi.ProgressPercent)%"></div>
                        </div>
                        <span class="pp-progress__pct">@kpi.ProgressPercent% of the way to target</span>
                    </div>

                    <dl class="pp-kpi-card__figures">
                        <div><dt>Baseline</dt><dd>@Fmt(kpi.BaselineValue) @kpi.Unit</dd></div>
                        <div><dt>Current</dt><dd class="pp-kpi-card__current">@Fmt(kpi.CurrentValue) @kpi.Unit</dd></div>
                        <div><dt>Target</dt><dd>@Fmt(kpi.TargetValue) @kpi.Unit</dd></div>
                    </dl>

                    <footer class="pp-kpi-card__foot">
                        @if (kpi.Measurements.Count > 0)
                        {
                            <details class="pp-history">
                                <summary class="pp-history__summary">
                                    <span>@kpi.MeasurementCount measurements</span>
                                    <svg class="pp-history__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </summary>
                                <ul class="pp-history__list">
                                    @foreach (var m in kpi.Measurements.OrderByDescending(x => x.CreatedDate))
                                    {
                                        <li class="pp-history__row">
                                            <span class="pp-history__value">@Fmt(m.Value) @kpi.Unit</span>
                                            <span class="pp-history__meta">
                                                <span class="pp-history__date">@m.CreatedDate.ToString("d MMM yyyy")</span>
                                                @if (!string.IsNullOrWhiteSpace(m.Notes))
                                                {
                                                    <span class="pp-history__note">@m.Notes</span>
                                                }
                                            </span>
                                            <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Edit measurement"
                                                    @onclick="() => OpenMeasurement(kpi, m)">
                                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                    <path d="M4 20h4l10-10a2.1 2.1 0 0 0-3-3L5 17v3Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                                                </svg>
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </details>
                        }
                        else
                        {
                            <span class="pp-history__summary pp-history__summary--static">0 measurements</span>
                        }
                        <button type="button" class="pp-btn pp-btn--ghost pp-btn--sm" @onclick="() => OpenMeasurement(kpi, null)">
                            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" aria-hidden="true">
                                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Add measurement
                        </button>
                    </footer>
                </article>
            }
        </div>
    }

    <CreateKpiDialog InitiativeId="Id" ObjectiveId="ObjectiveId" Visible="showCreateKpi"
                     OnClose="() => showCreateKpi = false" OnSaved="Reload" />

    <EditObjectiveDialog Objective="objective" Visible="showEditObjective"
                         OnClose="() => showEditObjective = false" OnSaved="Reload" />

    <EditKpiDialog InitiativeId="Id" Kpi="editingKpi" Visible="editingKpi is not null"
                   OnClose="() => editingKpi = null" OnSaved="Reload" />

    <MeasurementDialog InitiativeId="Id" ObjectiveId="ObjectiveId" Kpi="measurementKpi"
                       Measurement="editingMeasurement" Visible="measurementKpi is not null"
                       OnClose="CloseMeasurement" OnSaved="Reload" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    [Parameter] public Guid ObjectiveId { get; set; }

    private InitiativeVm? initiative;
    private ObjectiveVm? objective;
    private bool showCreateKpi;
    private bool showEditObjective;
    private KpiVm? editingKpi;
    private KpiVm? measurementKpi;
    private MeasurementVm? editingMeasurement;

    protected override void OnParametersSet()
    {
        initiative = Data.GetInitiative(Id);
        objective = Data.GetObjective(Id, ObjectiveId);
    }

    private void Reload()
    {
        initiative = Data.GetInitiative(Id);
        objective = Data.GetObjective(Id, ObjectiveId);
    }

    private void OpenMeasurement(KpiVm kpi, MeasurementVm? measurement)
    {
        editingMeasurement = measurement;
        measurementKpi = kpi;
    }

    private void CloseMeasurement()
    {
        measurementKpi = null;
        editingMeasurement = null;
    }

    private static string Fmt(decimal value) =>
        value == Math.Truncate(value) ? value.ToString("0") : value.ToString("0.##");

    private static readonly System.Globalization.CultureInfo Culture =
        System.Globalization.CultureInfo.InvariantCulture;

    // Sparkline geometry (matches the SVG viewBox in markup).
    private const double SparkWidth = 250;
    private const double SparkHeight = 44;
    private const double SparkPadding = 5;

    private readonly record struct Sparkline(string Points, double LastX, double LastY);

    /// <summary>Maps measurement values (oldest → newest) to polyline points across a
    /// fixed 250×44 viewBox, returning the point string plus the final point for the marker.</summary>
    private static Sparkline BuildSparkline(IReadOnlyList<decimal> values)
    {
        var count = values.Count;
        var min = values.Min();
        var max = values.Max();
        var range = max - min;
        var innerW = SparkWidth - (SparkPadding * 2);
        var innerH = SparkHeight - (SparkPadding * 2);

        var points = new string[count];
        double lastX = 0, lastY = 0;
        for (var i = 0; i < count; i++)
        {
            var x = SparkPadding + (count == 1 ? innerW / 2 : innerW * i / (count - 1));
            var norm = range == 0 ? 0.5 : (double)((values[i] - min) / range);
            var y = SparkPadding + (innerH * (1 - norm));
            points[i] = FormattableString.Invariant($"{x:0.#},{y:0.#}");
            lastX = x;
            lastY = y;
        }

        return new Sparkline(string.Join(" ", points), lastX, lastY);
    }

    /// <summary>Human-readable recency string for the meta row.</summary>
    private static string RecencyLabel(KpiVm kpi) => kpi.DaysSinceLastMeasured switch
    {
        null => "No measurements logged yet",
        <= 0 => "Last logged today",
        1 => "Last logged yesterday",
        var days => $"Last logged {days} days ago",
    };
}
