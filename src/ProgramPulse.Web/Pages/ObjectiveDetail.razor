@page "/programmes/{Id:guid}/objectives/{ObjectiveId:guid}"
@layout DashboardLayout
@inject ProgrammesApiClient ProgrammesApi
@inject KpisApiClient KpisApi
@inject MeasurementsApiClient MeasurementsApi

<PageTitle>@(objective?.Name ?? "Objective") — ProgramPulse</PageTitle>

@if (_loading)
{
    <nav class="pp-crumbs" aria-label="Breadcrumb">
        <a href="/programmes">Programmes</a>
        <span class="pp-crumbs__sep">/</span>
        <span class="pp-crumbs__current">Loading…</span>
    </nav>
    <p class="pp-page__subtitle">Loading objective…</p>
}
else if (programme is null || objective is null)
{
    <nav class="pp-crumbs" aria-label="Breadcrumb">
        <a href="/programmes">Programmes</a>
        <span class="pp-crumbs__sep">/</span>
        <span class="pp-crumbs__current">Unavailable</span>
    </nav>
    <div class="pp-empty">
        <p class="pp-empty__title">Couldn't load this objective</p>
        <p class="pp-empty__note">It may have been removed, or the server is unreachable. Head back to the <a class="pp-auth__link" href="/programmes">programmes list</a>.</p>
    </div>
}
else
{
    <nav class="pp-crumbs" aria-label="Breadcrumb">
        <a href="/programmes">Programmes</a>
        <span class="pp-crumbs__sep">/</span>
        <a href="/programmes/@programme.Id">@programme.Name</a>
        <span class="pp-crumbs__sep">/</span>
        <span class="pp-crumbs__current">@objective.Name</span>
    </nav>

    <header class="pp-detail__head">
        <div class="pp-detail__title-row">
            <h1 class="pp-dash__heading">@objective.Name</h1>
            <span class="pp-badge pp-badge--@StatusRollup.Modifier(objective.AggregateStatus)">
                @StatusRollup.Label(objective.AggregateStatus)
            </span>
            <button type="button" class="pp-btn pp-btn--ghost" @onclick="() => showEditObjective = true">
                <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
                    <path d="M4 20h4l10-10a2.1 2.1 0 0 0-3-3L5 17v3Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Edit
            </button>
        </div>
        <p class="pp-detail__desc">@objective.Description</p>
    </header>

    <div class="pp-section-head-row">
        <h2 class="pp-section-head">Key performance indicators</h2>
        <div class="pp-select pp-select--sm">
            <select class="pp-input" aria-label="Filter KPIs by category"
                    value="@(categoryFilter?.ToString() ?? "")" @onchange="OnCategoryFilterChanged">
                <option value="">All categories</option>
                <option value="@KpiCategory.Operational">Operational</option>
                <option value="@KpiCategory.Strategic">Strategic</option>
                <option value="@KpiCategory.Priority">Priority</option>
            </select>
            <svg class="pp-select__chevron" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <button type="button" class="pp-btn pp-btn--ghost pp-btn--sm" @onclick="() => showAddKpi = true">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" aria-hidden="true">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Add KPI
        </button>
    </div>

    @if (objective.Kpis.Count == 0)
    {
        <div class="pp-empty">
            @if (categoryFilter is not null)
            {
                <p class="pp-empty__title">No matching KPIs</p>
                <p class="pp-empty__note">No KPIs in the @categoryFilter category. Try a different filter.</p>
            }
            else
            {
                <p class="pp-empty__title">No KPIs yet</p>
                <p class="pp-empty__note">This objective has no KPIs. Add one to start tracking progress.</p>
            }
        </div>
    }
    else
    {
        <ul class="pp-kpi-list">
            @foreach (var kpi in objective.Kpis)
            {
                <li class="pp-kpi-row" role="button" tabindex="0"
                    @onclick="() => selectedKpi = kpi"
                    @onkeydown="e => OnRowKeyDown(e, kpi)"
                    aria-label="View details for @kpi.Name">
                    <span class="pp-kpi-row__stripe pp-kpi-card__stripe--@kpi.StatusModifier" aria-hidden="true"></span>

                    <div class="pp-kpi-row__main">
                        <h3 class="pp-kpi-row__name">@kpi.Name</h3>
                        <span class="pp-badge pp-badge--@kpi.StatusModifier">@kpi.StatusLabel</span>
                    </div>

                    <div class="pp-kpi-row__figure">
                        <span class="pp-kpi-row__value">@Fmt(kpi.CurrentValue) / @Fmt(kpi.TargetValue)</span>
                        <span class="pp-kpi-row__unit">@kpi.Unit</span>
                    </div>

                    <div class="pp-kpi-row__progress">
                        <div class="pp-progress__track">
                            <div class="pp-progress__fill pp-progress__fill--@kpi.StatusModifier" style="width:@(kpi.ProgressPercent)%"></div>
                        </div>
                        <span class="pp-progress__pct">@kpi.ProgressPercent%</span>
                    </div>

                    <div class="pp-kpi-row__due">
                        <span class="pp-kpi-row__due-date @(kpi.IsOverdue ? "pp-kpi-row__due-date--over" : "")">
                            Due @kpi.DueDate.ToString("d MMM yyyy")@(kpi.IsOverdue ? " · overdue" : "")
                        </span>
                        <span class="pp-kpi-row__recency @(kpi.IsMeasurementOverdue ? "pp-kpi-row__recency--warn" : "")">@RecencyLabel(kpi)</span>
                    </div>

                    <div class="pp-kpi-row__actions">
                        <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Edit KPI"
                                @onclick="() => editingKpi = kpi" @onclick:stopPropagation="true">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M4 20h4l10-10a2.1 2.1 0 0 0-3-3L5 17v3Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>
                        <button type="button" class="pp-iconbtn pp-iconbtn--sm" aria-label="Delete KPI"
                                @onclick="() => DeleteKpi(kpi)" @onclick:stopPropagation="true" disabled="@_deleting">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M6 7h12M9 7V5h6v2m-8 0 1 12h8l1-12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>
                    </div>
                </li>
            }
        </ul>
    }

    <KpiDetailDialog Kpi="selectedKpi" Visible="selectedKpi is not null"
                     OnClose="() => selectedKpi = null"
                     OnEditKpi="() => editingKpi = selectedKpi"
                     OnAddMeasurement="() => OpenMeasurement(selectedKpi!, null)"
                     OnEditMeasurement="m => OpenMeasurement(selectedKpi!, m)" />

    <EditObjectiveDialog Objective="objective" Visible="showEditObjective"
                         OnClose="() => showEditObjective = false" OnSaved="Reload" />

    <EditKpiDialog ProgrammeId="Id" Kpi="editingKpi" Visible="editingKpi is not null"
                   OnClose="() => editingKpi = null" OnSaved="Reload" />

    <AddKpiDialog ObjectiveId="ObjectiveId" Visible="showAddKpi"
                  OnClose="() => showAddKpi = false" OnSaved="Reload" />

    <MeasurementDialog ProgrammeId="Id" ObjectiveId="ObjectiveId" Kpi="measurementKpi"
                       Measurement="editingMeasurement" Visible="measurementKpi is not null"
                       OnClose="CloseMeasurement" OnSaved="Reload" />
}

@code {
    [Parameter] public Guid Id { get; set; }
    [Parameter] public Guid ObjectiveId { get; set; }

    private ProgrammeVm? programme;
    private ObjectiveVm? objective;
    private bool showEditObjective;
    private bool showAddKpi;
    private KpiVm? editingKpi;
    private KpiVm? selectedKpi;
    private KpiVm? measurementKpi;
    private MeasurementVm? editingMeasurement;
    private bool _loading = true;
    private bool _deleting;

    // Server-side KPI category filter; null means "all categories".
    private KpiCategory? categoryFilter;

    protected override Task OnParametersSetAsync() => LoadAsync();

    private Task Reload() => LoadAsync();

    // Category filter is applied server-side, so a change re-queries the KPI list.
    private Task OnCategoryFilterChanged(ChangeEventArgs e)
    {
        categoryFilter = Enum.TryParse<KpiCategory>(e.Value?.ToString(), out var category)
            ? category
            : null;
        return LoadAsync();
    }

    // Objective metadata (name/description/breadcrumb) has no dedicated endpoint, so it comes
    // from the parent programme's detail tree; the KPI cards come from the objective's KPIs endpoint.
    private async Task LoadAsync()
    {
        _loading = true;

        var detail = await ProgrammesApi.GetProgrammeDetailAsync(Id, CancellationToken.None);
        var objectiveDetail = detail?.Objectives.FirstOrDefault(o => o.Id == ObjectiveId);

        if (detail is null || objectiveDetail is null)
        {
            programme = null;
            objective = null;
            _loading = false;
            return;
        }

        // An objective can have many KPIs; null only on a load failure (empty list is shown as empty state).
        var kpis = await KpisApi.GetObjectiveKpisAsync(ObjectiveId, CancellationToken.None, categoryFilter) ?? [];
        var kpiVms = new List<KpiVm>();
        foreach (var kpi in kpis)
        {
            kpiVms.Add(await ToKpiVmAsync(kpi));
        }

        programme = new ProgrammeVm(
            detail.Id, detail.Name, detail.Description, detail.StartDate, detail.EndDate,
            detail.CreatedDate, detail.LastModifiedDate, Array.Empty<ObjectiveVm>());

        objective = new ObjectiveVm(
            objectiveDetail.Id, objectiveDetail.Name, objectiveDetail.Description,
            objectiveDetail.ProgrammeId, objectiveDetail.CreatedDate, objectiveDetail.LastModifiedDate,
            kpiVms);

        // Re-resolve the open detail modal against the freshly-rebuilt KPI list so it shows the
        // reloaded data (e.g. a just-added measurement) rather than a stale instance.
        selectedKpi = selectedKpi is null ? null : kpiVms.FirstOrDefault(k => k.Id == selectedKpi.Id);

        _loading = false;
    }

    private void OnRowKeyDown(KeyboardEventArgs e, KpiVm kpi)
    {
        if (e.Key is "Enter" or " ")
        {
            selectedKpi = kpi;
        }
    }

    private async Task DeleteKpi(KpiVm kpi)
    {
        _deleting = true;
        await KpisApi.DeleteKpiAsync(kpi.Id, CancellationToken.None);
        _deleting = false;
        await LoadAsync();
    }

    private async Task<KpiVm> ToKpiVmAsync(KpiResponse k)
    {
        var measurements = await MeasurementsApi.GetMeasurementsAsync(k.Id, CancellationToken.None) ?? [];
        var measurementVms = measurements
            .Select(m => new MeasurementVm(m.Id, m.Value, m.Notes, m.KpiId, m.MeasurementDate, m.CreatedDate))
            .ToList();

        return new KpiVm(
            k.Id, k.Name, k.Unit, k.Category, k.Direction, k.BaselineValue, k.TargetValue, k.CurrentValue,
            k.DueDate, k.Status, k.ObjectiveId, k.CreatedDate, k.LastModifiedDate,
            k.Strategies, k.Activities, k.KeyOutputs, k.PerformanceMeasure, measurementVms);
    }

    private void OpenMeasurement(KpiVm kpi, MeasurementVm? measurement)
    {
        editingMeasurement = measurement;
        measurementKpi = kpi;
    }

    private void CloseMeasurement()
    {
        measurementKpi = null;
        editingMeasurement = null;
    }

    private static string Fmt(decimal value) =>
        value == Math.Truncate(value) ? value.ToString("0") : value.ToString("0.##");

    /// <summary>Human-readable recency string for the row.</summary>
    private static string RecencyLabel(KpiVm kpi) => kpi.DaysSinceLastMeasured switch
    {
        null => "No measurements logged yet",
        <= 0 => "Last logged today",
        1 => "Last logged yesterday",
        var days => $"Last logged {days} days ago",
    };
}
