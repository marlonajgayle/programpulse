@page "/programmes"
@layout DashboardLayout
@inject ProgrammesApiClient ProgrammesApi
@inject NavigationManager Nav

<PageTitle>Programmes — ProgramPulse</PageTitle>

<div class="pp-page__head">
    <div>
        <h1 class="pp-dash__heading">Programmes</h1>
        <p class="pp-page__subtitle">@_totalCount top-level @(_totalCount == 1 ? "programme" : "programmes") across your workspace.</p>
    </div>
    <button type="button" class="pp-btn pp-btn--primary" @onclick="() => showCreate = true">
        <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        New programme
    </button>
</div>

<div class="pp-toolbar">
    <div class="pp-topbar__search pp-toolbar__search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7" />
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
        </svg>
        <input class="pp-input pp-input--icon" type="search" placeholder="Filter this page"
               aria-label="Filter programmes on this page" value="@_search"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty" />
    </div>
    @* Search filters the current page only; with server-side pagination the other pages
       aren't in memory. A full-dataset search would need a server-side search param. *@
</div>

@if (_loading)
{
    <p class="pp-page__subtitle">Loading programmes…</p>
}
else if (_loadFailed)
{
    <div class="pp-empty">
        <p class="pp-empty__title">Couldn't load programmes</p>
        <p class="pp-empty__note">The server is unreachable right now. Please try again later.</p>
    </div>
}
else if (_totalCount == 0)
{
    <div class="pp-empty">
        <p class="pp-empty__title">No programmes yet</p>
        <p class="pp-empty__note">Create your first programme to start tracking objectives and KPIs.</p>
    </div>
}
else
{
    var visible = Filtered();

    @if (visible.Count == 0)
    {
        <div class="pp-empty">
            <p class="pp-empty__title">No programmes match your filter</p>
            <p class="pp-empty__note">Try a different search term, or clear the filter.</p>
            <button type="button" class="pp-btn pp-btn--ghost" @onclick="() => _search = string.Empty">Clear filter</button>
        </div>
    }
    else
    {
        <div class="pp-tree" role="tree" aria-label="Programmes">
            @foreach (var parent in visible)
            {
                var expanded = _expanded.Contains(parent.Id);
                var hasChildren = parent.Children.Count > 0;

                <div class="pp-tree__group" role="treeitem" aria-expanded="@(hasChildren ? expanded : (bool?)null)">
                    <div class="pp-tree__row @(expanded ? "is-open" : null)">
                        @if (hasChildren)
                        {
                            <button type="button" class="pp-tree__toggle" aria-expanded="@expanded"
                                    aria-label="@(expanded ? "Collapse" : "Expand") @parent.Name"
                                    @onclick="() => Toggle(parent.Id)" @onclick:stopPropagation="true">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </button>
                        }
                        else
                        {
                            <span class="pp-tree__toggle pp-tree__toggle--leaf" aria-hidden="true"></span>
                        }

                        <ProgrammeTreeRow Programme="parent" IsChild="false" OnOpen="Open" OnEdit="OpenEdit" />
                    </div>

                    @if (expanded && hasChildren)
                    {
                        <div class="pp-tree__children" role="group">
                            @foreach (var child in parent.Children)
                            {
                                <div class="pp-tree__row pp-tree__row--child" role="treeitem">
                                    <span class="pp-tree__toggle pp-tree__toggle--leaf" aria-hidden="true"></span>
                                    <ProgrammeTreeRow Programme="child" IsChild="true" OnOpen="Open" OnEdit="OpenEdit" />
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @if (_totalPages > 1)
        {
            <div class="pp-pagination">
                <button type="button" class="pp-btn pp-btn--ghost pp-btn--sm" disabled="@(_page == 1)" @onclick="PrevPage">
                    ← Previous
                </button>
                <div class="pp-pagination__pages">
                    @for (var p = 1; p <= _totalPages; p++)
                    {
                        var pageNumber = p;
                        <button type="button" class="pp-pagination__page @(pageNumber == _page ? "is-active" : "")"
                                @onclick="() => GoToPage(pageNumber)">
                            @pageNumber.ToString("00")
                        </button>
                    }
                </div>
                <button type="button" class="pp-btn pp-btn--ghost pp-btn--sm" disabled="@(_page == _totalPages)" @onclick="NextPage">
                    Next →
                </button>
            </div>
        }
    }
}

<CreateProgrammeDialog Visible="showCreate" OnClose="() => showCreate = false" OnCreated="ReloadAsync" />
<EditProgrammeDialog Visible="_showEdit" Programme="_editing" OnClose="CloseEdit" OnSaved="ReloadAsync" />

@code {
    private const int PageSize = 10;

    private IReadOnlyList<ProgrammeVm> _parents = Array.Empty<ProgrammeVm>();
    private readonly HashSet<Guid> _expanded = new();
    private string _search = string.Empty;
    private int _page = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private bool showCreate;
    private bool _showEdit;
    private ProgrammeVm? _editing;
    private bool _loading = true;
    private bool _loadFailed;

    protected override Task OnInitializedAsync() => LoadAsync(1);

    private Task ReloadAsync() => LoadAsync(_page);

    private async Task LoadAsync(int page)
    {
        _loading = true;
        var result = await ProgrammesApi.GetProgrammesAsync(page, PageSize, CancellationToken.None);
        _loadFailed = result is null;

        if (result is not null)
        {
            _parents = result.Items.Select(ToVm).ToList();
            _page = result.Page;
            _totalPages = Math.Max(1, result.TotalPages);
            _totalCount = result.TotalCount;
        }
        else
        {
            _parents = Array.Empty<ProgrammeVm>();
        }

        _loading = false;
    }

    // The list endpoint returns objective/KPI counts but not the KPI sub-tree, so rows
    // show counts and lifecycle status (both derivable) rather than a KPI roll-up.
    private static ProgrammeVm ToVm(ProgrammeResponse r) => new(
        r.Id, r.Name, r.Description, r.StartDate, r.EndDate,
        r.CreatedDate, r.LastModifiedDate, Array.Empty<ObjectiveVm>(),
        ObjectiveCountOverride: r.ObjectiveCount,
        KpiCountOverride: r.KpiCount,
        ParentProgrammeId: r.ParentProgrammeId,
        SubProgrammes: (r.SubProgrammes ?? Array.Empty<ProgrammeResponse>()).Select(ToVm).ToList());

    private void Toggle(Guid id)
    {
        if (!_expanded.Remove(id))
        {
            _expanded.Add(id);
        }
    }

    private void Open(Guid id) => Nav.NavigateTo($"/programmes/{id}");

    private void OpenEdit(ProgrammeVm programme)
    {
        _editing = programme;
        _showEdit = true;
    }

    private void CloseEdit()
    {
        _showEdit = false;
        _editing = null;
    }

    // Search filters the loaded page's parents by name/description (current page only).
    private IReadOnlyList<ProgrammeVm> Filtered()
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return _parents;
        }

        var term = _search.Trim();
        return _parents
            .Where(p => p.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
                || p.Description.Contains(term, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task PrevPage() { if (_page > 1) await LoadAsync(_page - 1); }
    private async Task NextPage() { if (_page < _totalPages) await LoadAsync(_page + 1); }
    private async Task GoToPage(int page) { if (page != _page) await LoadAsync(page); }
}
