@page "/dashboard"
@layout DashboardLayout
@inject SampleData Data

<PageTitle>Dashboard — ProgramPulse</PageTitle>

@if (_summary is null)
{
    <p class="pp-page__subtitle">Loading portfolio…</p>
}
else
{
    <!-- ===== 1. Header row ===== -->
    <header class="pp-dash__header">
        <div>
            <h1 class="pp-dash__heading">Portfolio overview</h1>
            <p class="pp-page__subtitle">@_summary.TeamName · @_summary.ActiveInitiativeCount active initiatives</p>
        </div>
        <span class="pp-dash__updated">Updated @_summary.MinutesAgo min ago</span>
    </header>

    <!-- ===== 2. Metric card row ===== -->
    <section class="pp-metric-row">
        <MetricCard Label="Portfolio health"
                    Value="@_summary.HealthScore.ToString()"
                    Denominator="100"
                    Subline="@HealthDelta"
                    Accent="true" />

        <MetricCard Label="On track"
                    Value="@_summary.Status.OnTrack.ToString()"
                    Denominator="@_summary.Status.Total.ToString()"
                    Subline="@($"{_summary.OnTrackPercent}% of initiatives")"
                    StatusModifier="track" />

        <MetricCard Label="At risk"
                    Value="@_summary.Status.AtRisk.ToString()"
                    Denominator="@_summary.Status.Total.ToString()"
                    Subline="@AtRiskDelta"
                    StatusModifier="warn"
                    TintSubline="true" />

        <MetricCard Label="Off track"
                    Value="@_summary.Status.OffTrack.ToString()"
                    Denominator="@_summary.Status.Total.ToString()"
                    Subline="Needs intervention"
                    StatusModifier="off"
                    TintSubline="true" />

        <MetricCard Label="Overdue KPIs"
                    Value="@_summary.OverdueKpiCount.ToString()"
                    Denominator="@_summary.TotalKpiCount.ToString()"
                    Subline="No measurement >14d"
                    StatusModifier="warn" />
    </section>

    <!-- ===== 3. Middle row ===== -->
    <section class="pp-dash__mid">
        <AttentionList Items="_summary.Flagged" />
        <StatusTrendChart Points="_summary.Trend" />
    </section>

    <!-- ===== 4. Bottom row ===== -->
    <section class="pp-dash__bottom">
        <ReviewList Items="_summary.Reviews" />
        <VelocityPanel Stats="_summary.Velocity" />
    </section>
}

@code {
    private DashboardSummaryVm? _summary;

    protected override void OnInitialized() => _summary = Data.GetDashboardSummary();

    private string HealthDelta =>
        $"{(_summary!.HealthDeltaPercent >= 0 ? "▲" : "▼")} {Math.Abs(_summary.HealthDeltaPercent):0.#}% vs last week";

    private string AtRiskDelta =>
        _summary!.AtRiskDeltaSinceLastWeek == 0
            ? "No change since last week"
            : $"▲ {_summary.AtRiskDeltaSinceLastWeek} since last week";
}
