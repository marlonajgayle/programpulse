{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "Endpoint": "/health"
  },
  "IpRateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "SecurityHeaders": {
    "Enabled": true
  },
  "AllowedHosts": "*"
}
