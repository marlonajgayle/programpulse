@model ProgramPulse.Api.Features.Notifications.WelcomeEmailModel
<!DOCTYPE html>
<html lang="en">
<body style="font-family: Arial, sans-serif; color: #222;">
    <h2>Welcome to ProgramPulse, @Model.UserName!</h2>
    <p>
        Thanks for joining. Your account is ready to go — we're glad to have you
        on board.
    </p>
    <p>If you have any questions, just reply to this email.</p>
    <p>— The ProgramPulse Team</p>
</body>
</html>
