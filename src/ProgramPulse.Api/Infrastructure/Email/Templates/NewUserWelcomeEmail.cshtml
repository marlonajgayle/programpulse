@model ProgramPulse.Api.Features.Notifications.NewUserWelcomeEmailModel
<!DOCTYPE html>
<html lang="en">
<body style="font-family: Arial, sans-serif; color: #222;">
    <h2>Welcome to ProgramPulse, @Model.FirstName!</h2>
    <p>
        An administrator has created an account for you. Use the temporary
        password below to sign in:
    </p>
    <p style="font-size: 18px; font-weight: bold; letter-spacing: 1px;">
        @Model.TemporaryPassword
    </p>
    <p>
        For your security, please change this password as soon as you sign in.
    </p>
    <p>If you have any questions, just reply to this email.</p>
    <p>— The ProgramPulse Team</p>
</body>
</html>
